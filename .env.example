# HTTP
PORT=8787
HOST=0.0.0.0

# Postgres — Supabase: project home → Connect → Session pooler :5432 (not Settings; not direct db.* on Windows)
DATABASE_URL=postgresql://postgres.YOUR_PROJECT_REF:YOUR_PASSWORD@aws-0-eu-central-1.pooler.supabase.com:5432/postgres

# HMAC auth (must match plugin signing key — production value is the decoded daf_cloud_index_production_signing_key() constant)
PLUGIN_HMAC_SECRET=d75be2208c50352676d425adc41339da

# Stripe
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_CLOUD_STARTER=price_...
STRIPE_PRICE_CLOUD_GROWTH=price_...
STRIPE_PRICE_CLOUD_SCALE=price_...

# Typesense admin (shared cluster)
TYPESENSE_HOST=cloud-catalog.diviengine.com
TYPESENSE_PORT=443
TYPESENSE_PROTOCOL=https
TYPESENSE_ADMIN_API_KEY=

# Billing URLs
CHECKOUT_SUCCESS_URL=https://diviengine.com/cloud-index/checkout-success
CHECKOUT_CANCEL_URL=https://diviengine.com/cloud-index/checkout-cancel
STRIPE_PORTAL_RETURN_URL=https://diviengine.com/cloud-index/portal-return

# Trial
CLOUD_INDEX_TRIAL_DAYS=14
CLOUD_INDEX_CANCEL_GRACE_DAYS=7

# Admin dashboard (optional — /admin UI + /v1/admin/* APIs)
ADMIN_PASSWORD=change-me-min-8-chars
ADMIN_SESSION_SECRET=change-me-min-16-chars-long
ADMIN_SESSION_TTL_HOURS=24
# Set to false for local HTTP dev without HTTPS
ADMIN_COOKIE_SECURE=true
